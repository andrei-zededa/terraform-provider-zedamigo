version: 2
renderer: networkd

ethernets:
  # Management NIC = QEMU user-mode networking (nic0). Matched by QEMU's default
  # MAC. DHCP gives it 10.0.2.15 and outbound Internet (used for SSH and for
  # cloud-init package installation).
  mgmt:
    match:
      macaddress: "52:54:00:12:34:56"
    dhcp4: true
    dhcp6: false

  # The two bond members, matched by the MACs set on the QEMU `-nic ...` devices
  # in test_vm_with_cloud_init.tf. They carry no addresses of their own.
  lagm0:
    match:
      macaddress: "52:54:00:00:0a:01"
    dhcp4: false
    dhcp6: false
  lagm1:
    match:
      macaddress: "52:54:00:00:0a:02"
    dhcp4: false
    dhcp6: false

bonds:
  bond0:
    interfaces:
      - lagm0
      - lagm1
    addresses:
      - 10.10.10.2/24
    dhcp4: false
    dhcp6: false
    parameters:
      # Must match the host-side zedamigo_lag (mode 802.3ad, lacp_rate fast,
      # miimon 100, xmit_hash_policy layer3+4) for LACP to aggregate both links.
      mode: 802.3ad
      lacp-rate: fast
      mii-monitor-interval: 100
      transmit-hash-policy: layer3+4
